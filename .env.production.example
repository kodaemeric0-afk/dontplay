# Example .env.production for dontplay
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
SESSION_SECRET=__GENERATE_SESSION_SECRET__
SESSION_NAME=sid
BCRYPT_ROUNDS=12
SMS_STORAGE_PATH=/var/lib/dontplay/sms.json
DB_PATH=/var/lib/dontplay/db.json
DEV_SMS_SECRET=localdevsecret
ENABLE_DEV_SEND_SMS=false

# Optional Redis session store
REDIS_URL=redis://localhost:6379
USE_REDIS_SESSIONS=false

# Production email/admin
ADMIN_EMAIL=admin@dontplay.net

# Rate limits
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=5
